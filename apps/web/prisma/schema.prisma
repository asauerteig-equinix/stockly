generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER_ADMIN
  ADMIN
}

enum MovementType {
  TAKE
  RETURN
  GOODS_RECEIPT
  CORRECTION
}

enum SourceType {
  ADMIN
  KIOSK
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String
  passwordHash      String
  role              Role
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  sessions          AdminSession[]
  assignedLocations UserLocation[]
  createdMovements  StockMovement[] @relation("CreatedByUser")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  updatedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderUpdatedBy")
}

model AdminSession {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Location {
  id                String             @id @default(cuid())
  name              String
  code              String             @unique
  description       String?
  kioskPinHash      String
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  settings          LocationSettings?
  articles          Article[]
  inventoryBalances InventoryBalance[]
  stockMovements    StockMovement[]
  kioskDevices      KioskDevice[]
  adminAssignments  UserLocation[]
  purchaseOrders    PurchaseOrder[]

  @@index([isActive])
}

model UserLocation {
  userId     String
  locationId String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([userId, locationId])
  @@index([locationId])
}

model LocationSettings {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  agingWarningDays   Int      @default(30)
  allowNegativeStock Boolean  @default(false)
  lowStockBuffer     Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Article {
  id                 String            @id @default(cuid())
  locationId         String
  name               String
  barcode            String
  articleBarcodes    ArticleBarcode[]
  imageUrl           String?
  description        String?
  manufacturerNumber String?
  supplierNumber     String?
  category           String
  sortOrder          Int               @default(0)
  minimumStock       Int               @default(0)
  isArchived         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  location           Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  inventoryBalance   InventoryBalance?
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([locationId, barcode])
  @@index([locationId, name])
  @@index([locationId, category, sortOrder])
  @@index([isArchived])
}

model ArticleImage {
  id           String   @id @default(cuid())
  fileName     String   @unique
  originalName String
  mimeType     String
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([createdAt])
}

model ArticleBarcode {
  id         String   @id @default(cuid())
  articleId   String
  locationId String
  barcode    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([locationId, barcode])
  @@unique([articleId, barcode])
  @@index([articleId])
}

model InventoryBalance {
  id             String    @id @default(cuid())
  locationId     String
  articleId      String    @unique
  quantity       Int       @default(0)
  lastMovementAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  location       Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  article        Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([locationId, quantity])
}

model StockMovement {
  id              String       @id @default(cuid())
  locationId      String
  articleId       String
  type            MovementType
  sourceType      SourceType
  quantity        Int
  usageReason     String?
  note            String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  location        Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  article         Article      @relation(fields: [articleId], references: [id], onDelete: Restrict)
  createdByUser   User?        @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([locationId, createdAt(sort: Desc)])
  @@index([articleId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  orderNumber     String              @unique
  locationId      String
  status          PurchaseOrderStatus @default(DRAFT)
  note            String?
  createdByUserId String
  updatedByUserId String?
  location        Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdByUser   User                @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser   User?               @relation("PurchaseOrderUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  items           PurchaseOrderItem[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  submittedAt     DateTime?

  @@index([locationId, status])
  @@index([createdByUserId])
  @@index([updatedByUserId])
  @@index([createdAt])
}

model PurchaseOrderItem {
  id                       String        @id @default(cuid())
  purchaseOrderId          String
  articleId                String
  quantity                 Int
  suggestedQuantity        Int           @default(1)
  articleNameSnapshot      String
  barcodeSnapshot          String
  categorySnapshot         String
  imageUrlSnapshot         String?
  currentQuantitySnapshot  Int           @default(0)
  minimumStockSnapshot     Int           @default(0)
  manufacturerNumberSnapshot String?
  supplierNumberSnapshot   String?
  purchaseOrder            PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  article                  Article       @relation(fields: [articleId], references: [id], onDelete: Restrict)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@unique([purchaseOrderId, articleId])
  @@index([purchaseOrderId])
  @@index([articleId])
}

model KioskDevice {
  id         String   @id @default(cuid())
  locationId String
  label      String
  tokenHash  String   @unique
  isActive   Boolean  @default(true)
  pairedAt   DateTime @default(now())
  lastSeenAt DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, isActive])
}
