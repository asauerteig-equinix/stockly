POSTGRES_DB=stockly
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Interner Docker-Hostname fuer PostgreSQL im Stack.
# Absichtlich nicht einfach "db", damit es in geteilten Netzwerken keine Namenskollisionen gibt.
DATABASE_HOST=stockly-db
BASE_PATH=
# Fuer Unterpfad-Deploys z. B.:
# BASE_PATH=/stockly
# Fuer reinen Direktzugriff:
APP_URL=http://localhost:5600
# Hinter einem HTTPS-Reverse-Proxy stattdessen z. B.:
# APP_URL=https://xxx.xxx.xxx/stockly
SESSION_SECRET=session-FoVPewdfooyV8G6yud6a
KIOSK_SECRET=k!0sk-FoVPewdfooyV8G6yud6a
# Hinter HTTPS-Proxy auf true setzen.
COOKIE_SECURE=false
AUTO_SEED=true
# Lokal false lassen. Auf dem Server true setzen, wenn das Netz bereits vom Reverse Proxy existiert.
REVERSE_PROXY_NETWORK_EXTERNAL=false
# Name des Reverse-Proxy-Netzes. Lokal wird es bei EXTERNAL=false automatisch angelegt.
REVERSE_PROXY_NETWORK=stockly-proxy
# Eindeutiger Hostname der Web-App im gemeinsamen Reverse-Proxy-Netz.
APP_NETWORK_ALIAS=stockly-app
